procedure main()
  shared mutable can_bond := barrier(3)
  shared mutable oxygen_queue := semaphore(1)
  shared mutable hydrogen_queue := semaphore(2)
  shared mutable h_count := 0
  shared mutable o_count := 0
  shared mutable molecule_count := 0
  shared mutable bond_mutex as mutex := mutex()
  mutable oxygen_count := 0
  mutable hydrogen_count := 0
  mutable atom as char
  while scan `{atom}` do
    case atom of
      'H':
        create_thread(hydrogen, hydrogen_count)
        hydrogen_count := hydrogen_count + 1
      'O':
        create_thread(oxygen, oxygen_count)
        oxygen_count := oxygen_count + 1
    end case
  end while
end procedure

procedure hydrogen(id)
  wait(hydrogen_queue)
  wait(can_bond)
  bond('H', id)
  signal(hydrogen_queue)
end procedure

procedure oxygen(id)
  wait(oxygen_queue)
  wait(can_bond)
  bond('O', id)
  signal(oxygen_queue)
end procedure

procedure bond(atom as char, id)
  lock(bond_mutex)
  if atom = 'H' then
    h_count := h_count + 1
  else if atom = 'O' then
    o_count := o_count + 1
  else
    print "Error: invalid atom type"
  end if
  end if
  if h_count = 2 and o_count = 1 then
    molecule_count := molecule_count + 1
    h_count := 0
    o_count := 0
    unlock(bond_mutex)
    print `H2O molecule {molecule_count} formed (atom {atom} id {id})`
  else
    unlock(bond_mutex)
  end if
end procedure
