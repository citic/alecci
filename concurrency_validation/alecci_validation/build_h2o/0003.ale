procedure main()
  shared mutable hydrogen_multiplex := semaphore(2)
  shared mutable oxygen_multiplex := semaphore(1)
  shared mutable can_enter_device := barrier(3)
  shared mutable h_count := 0
  shared mutable o_count := 0
  shared mutable molecule_count := 0
  shared mutable bond_mutex as mutex := mutex()
  mutable atom as char
  while scan `{atom}` do
    case atom of
      'H': create_thread(hydrogen)
      'O': create_thread(oxygen)
    end case
  end while
end procedure

procedure bond(atom as char)
  lock(bond_mutex)
  if atom = 'H' then
    h_count := h_count + 1
  else if atom = 'O' then
    o_count := o_count + 1
  else
    print "Error: invalid atom type"
  end if
  end if
  if h_count = 2 and o_count = 1 then
    molecule_count := molecule_count + 1
    h_count := 0
    o_count := 0
    unlock(bond_mutex)
    print `H2O molecule {molecule_count} formed`
  else
    unlock(bond_mutex)
  end if
end procedure

procedure hydrogen()
  wait(hydrogen_multiplex)
    barrier_wait(can_enter_device)
    bond('H')
  signal(hydrogen_multiplex)
end procedure

procedure oxygen()
  wait(oxygen_multiplex)
    barrier_wait(can_enter_device)
    bond('O')
  signal(oxygen_multiplex)
end procedure
