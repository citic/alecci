procedure main(argc, argv)
  shared mutable player1_ready as semaphore := semaphore(0)
  shared mutable player2_ready as semaphore := semaphore(0)
  shared mutable clock_ready as semaphore := semaphore(0)
  create_thread(player1)
  create_thread(player2)
  create_thread(referee)
end procedure

procedure player1()
  print("player1 entered room")
  signal(player1_ready)
  wait(clock_ready)
  print("player1 playing chess")
end procedure

procedure player2()
  print("player2 entered room")
  signal(player2_ready)
  wait(clock_ready)
  print("player2 playing chess")
end procedure

procedure referee()
  print("referee entered room")
  wait(player1_ready)
  wait(player2_ready)
  print("clock set")
  signal(clock_ready, 2)
end procedure
