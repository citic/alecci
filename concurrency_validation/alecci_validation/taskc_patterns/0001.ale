procedure main(argc, argv)
  shared mutable a1_ready as semaphore := semaphore(0)
  mutable ta := create_thread(thread_a)
  mutable tb := create_thread(thread_b)
  join_thread(ta)
  join_thread(tb)
end procedure

procedure thread_a()
  print("a1")
  signal(a1_ready)
end procedure

procedure thread_b()
  wait(a1_ready)
  print("b1")
end procedure
