procedure main(argc, argv)
  shared mutable buffer_capacity := 4
  shared mutable count := 0
  shared mutable q as queue := queue(4)
  shared mutable can_produce as semaphore := semaphore(4)
  shared mutable can_consume as semaphore := semaphore(0)
  mutable producers as thread_array := create_threads(2, produce)
  mutable consumers as thread_array := create_threads(2, consume)
  join_threads(producers)
  join_threads(consumers)
end procedure

procedure produce(thread_number as int)
  mutable index := 0
  while index < 4 do
    wait(can_produce)
    sleep(rand() % 30, "ms")
    count := count + 1
    enqueue(q, count)
    print("Produced")
    signal(can_consume)
    index := index + 1
  end while
end procedure

procedure consume(thread_number as int)
  mutable index := 0
  while index < 4 do
    wait(can_consume)
    sleep(rand() % 20, "ms")
    mutable item := dequeue(q)
    print("Consumed")
    signal(can_produce)
    index := index + 1
  end while
end procedure
