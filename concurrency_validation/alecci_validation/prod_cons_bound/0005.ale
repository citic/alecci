procedure main(argc, argv)
  shared mutable buffer_capacity := 4
  shared mutable count := 0
  shared mutable q as queue := queue(4)
  shared mutable can_access_queue as mutex := mutex()
  mutable producers as thread_array := create_threads(2, produce)
  mutable consumers as thread_array := create_threads(2, consume)
  join_threads(producers)
  join_threads(consumers)
end procedure

procedure produce(thread_number as int)
  mutable index := 0
  while index < 5 do
    sleep(rand() % 30, "ms")
    count := count + 1
    lock(can_access_queue)
    enqueue(q, count)
    unlock(can_access_queue)
    print("Produced")
    index := index + 1
  end while
end procedure

procedure consume(thread_number as int)
  mutable index := 0
  while index < 5 do
    sleep(rand() % 20, "ms")
    lock(can_access_queue)
    mutable item := dequeue(q)
    unlock(can_access_queue)
    count := count - 1
    print("Consumed")
    index := index + 1
  end while
end procedure
