procedure main(argc, argv)
  shared mutable team_count := 5
  shared mutable position := 0
  mutable i := 0
  while i < team_count do
    create_thread(run_stage1)
    create_thread(run_stage2)
    i := i + 1
  end while
end procedure

procedure run_stage1()
  sleep(10)
  print("stage1 done")
end procedure

procedure run_stage2()
  sleep(20)
  // data race: position incremented without synchronization
  position := position + 1
  if position < 4 then
    print("finished")
  end if
end procedure
