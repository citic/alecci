procedure main(argc, argv)
  shared mutable team_count := 5
  shared mutable position := 0
  mutable t1 as thread_array := create_threads(team_count, run_stage1)
  mutable t2 as thread_array := create_threads(team_count, run_stage2)
  join_threads(t1)
  join_threads(t2)
end procedure

procedure run_stage1(thread_number as int)
  sleep(10, "ms")
  print("stage1 done")
end procedure

procedure run_stage2(thread_number as int)
  sleep(20, "ms")
  // data race: position incremented without synchronization
  position := position + 1
  if position < 4 then
    print("finished")
  end if
end procedure
