procedure main(argc, argv)
  shared mutable baton as semaphore := semaphore(0)
  shared mutable team_count := 3
  mutable i := 0
  while i < team_count do
    create_thread(leg1)
    create_thread(leg2)
    i := i + 1
  end while
end procedure

procedure leg1()
  sleep(rand() % 20)
  print("leg1 done")
end procedure

procedure leg2()
  wait(baton)
  print("leg2 done")
end procedure
