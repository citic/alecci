// RACE CONDITION: queue accessed without mutex — data race on queue internals
// next_unit and consumed_count are protected, but enqueue/dequeue are not
procedure main(argc, argv)
  shared mutable unit_count := 8
  shared mutable next_unit := 0
  shared mutable consumed_count := 0
  shared mutable q as queue := queue(64)
  shared mutable can_access_next as mutex := mutex()
  shared mutable can_access_consumed as mutex := mutex()
  shared mutable can_consume as semaphore := semaphore(0)
  mutable producers as thread_array := create_threads(2, produce)
  mutable consumers as thread_array := create_threads(2, consume)
  join_threads(producers)
  join_threads(consumers)
end procedure

procedure produce(thread_number as int)
  mutable running := 1
  while running = 1 do
    mutable my_unit := 0
    lock(can_access_next)
    if next_unit < unit_count then
      next_unit := next_unit + 1
      my_unit := next_unit
      unlock(can_access_next)
      sleep(rand() % 30)
      // BUG: enqueue without mutex — data race on queue internals
      enqueue(q, my_unit)
      print("Produced")
      signal(can_consume)
    else
      unlock(can_access_next)
      running := 0
    end if
  end while
end procedure

procedure consume(thread_number as int)
  mutable running := 1
  while running = 1 do
    lock(can_access_consumed)
    if consumed_count < unit_count then
      consumed_count := consumed_count + 1
      unlock(can_access_consumed)
      wait(can_consume)
      // BUG: dequeue without mutex — data race on queue internals
      mutable item := dequeue(q)
      sleep(rand() % 20)
      print("Consumed")
    else
      unlock(can_access_consumed)
      running := 0
    end if
  end while
end procedure
