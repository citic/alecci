// Barrier(2) + mutex semaphore: pair rendezvous then synchronized dance
procedure main(argc, argv)
  shared mutable male_queue as semaphore := semaphore(1)
  shared mutable female_queue as semaphore := semaphore(1)
  shared mutable pair_barrier as barrier := barrier(2)
  mutable genre as char
  while scan `{genre}` do
    case genre of
      'M': create_thread(male)
      'W': create_thread(female)
    end case
  end while
end procedure

procedure male()
  wait(male_queue)
  barrier_wait(pair_barrier)
  print("male dancing")
  barrier_wait(pair_barrier)
  signal(male_queue)
end procedure

procedure female()
  wait(female_queue)
  barrier_wait(pair_barrier)
  print("female dancing")
  barrier_wait(pair_barrier)
  signal(female_queue)
end procedure
