// Quartet barrier(4) + gender semaphores(2) + room capacity multiplex
procedure main(argc, argv)
  shared mutable salon_de_baile as semaphore := semaphore(16)
  shared mutable esperar_equipo as barrier := barrier(4)
  shared mutable falta_hombre as semaphore := semaphore(2)
  shared mutable falta_mujer as semaphore := semaphore(2)
  mutable genre as char
  while scan `{genre}` do
    case genre of
      'M': create_thread(male)
      'W': create_thread(female)
    end case
  end while
end procedure

procedure male()
  wait(falta_hombre)
  barrier_wait(esperar_equipo)
  wait(salon_de_baile)
  print("male dancing")
  signal(salon_de_baile)
  signal(falta_hombre)
end procedure

procedure female()
  wait(falta_mujer)
  barrier_wait(esperar_equipo)
  wait(salon_de_baile)
  print("female dancing")
  signal(salon_de_baile)
  signal(falta_mujer)
end procedure
