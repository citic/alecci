procedure main(argc, argv)
  shared mutable packet_count := 0
  shared mutable can_access_count as mutex := mutex()
  shared mutable can_produce as semaphore := semaphore(0)
  shared mutable can_consume as semaphore := semaphore(0)
  create_threads(2, produce)
  create_threads(2, consume)
end procedure

procedure produce(thread_number as int)
  for i := 0 to 5 do
    wait(can_produce)
    lock(can_access_count)
    packet_count := packet_count + 1
    unlock(can_access_count)
    signal(can_consume)
  end for
end procedure

procedure consume(thread_number as int)
  for i := 0 to 5 do
    wait(can_consume)
    lock(can_access_count)
    packet_count := packet_count - 1
    unlock(can_access_count)
    sleep(rand() % 10)
    print("Packet consumed")
    signal(can_produce)
  end for
end procedure
