// SCTBench benchmark: concurrent-software-benchmarks/din_phil5_unsat.c
// 5 dining philosophers. Each philosopher acquires right fork then left fork,
// both while holding a global esbmc_m mutex (serialising the fork operations).
// TSan sees different acquisition orders for fork pairs across threads and
// reports a lock-order-inversion warning.
// Expected: deadlock warning from TSan (lock-order inversion on fork mutexes).

procedure philosopher(thread_number as int)
    mutable left  := thread_number
    mutable right := (thread_number + 1) % 5
    atomic do
    lock(forks[right])
    lock(forks[left])
    unlock(forks[left])
    unlock(forks[right])
    end atomic
end procedure

procedure main()
    shared mutable esbmc_m as mutex := mutex()
    shared mutable forks := array(5, mutex())
    mutable threads := create_threads(5, philosopher)
    join_threads(threads, 5)
end procedure
