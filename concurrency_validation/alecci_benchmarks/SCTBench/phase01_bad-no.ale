// SCTBench benchmark: concurrent-software-benchmarks/phase01_bad.c
// Two threads both run thread1. Bug: thread1 acquires mutex x twice without
// releasing between the two lock calls — POSIX mutexes are non-recursive,
// so the second pthread_mutex_lock(&x) deadlocks.
// TSan detects this as a lock-order-inversion (potential deadlock) warning.
// Expected: deadlock warning from TSan.

procedure thread1(thread_number as int)
    lock(x)
    unlock(x)
    lock(x)
    // missing unlock(x) before the next lock — deadlock
    lock(y)
    unlock(y)
    lock(y)
    unlock(y)
end procedure

procedure main()
    shared mutable x as mutex := mutex()
    shared mutable y as mutex := mutex()
    mutable threads := create_threads(2, thread1)
    join_threads(threads, 2)
end procedure
