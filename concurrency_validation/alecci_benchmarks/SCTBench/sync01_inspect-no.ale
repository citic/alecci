// SCTBench benchmark: inspect_examples/sync01.c
// Minimal 1-slot producer-consumer: one item produced and one consumed.
// Producer waits on 'empty' if slot is occupied; consumer waits on 'full' if empty.
// All accesses to num are under the mutex — no data race.
// Expected: no data race.

procedure producer(thread_number as int)
    lock(m)
    while num > 0 do
        cond_wait(empty, m)
    end while
    num := num + 1
    unlock(m)
    cond_signal(full)
end procedure

procedure consumer(thread_number as int)
    lock(m)
    while num = 0 do
        cond_wait(full, m)
    end while
    num := num - 1
    unlock(m)
    cond_signal(empty)
end procedure

procedure main()
    shared mutable m     as mutex   := mutex()
    shared mutable empty as condvar := condvar()
    shared mutable full  as condvar := condvar()
    shared mutable num := 0
    mutable t1 := create_threads(1, producer)
    mutable t2 := create_threads(1, consumer)
    join_threads(t1, 1)
    join_threads(t2, 1)
end procedure
