// SCTBench benchmark: concurrent-software-benchmarks/account_bad.c
// Three threads (deposit, withdraw, check_result) share one mutex protecting balance.
// BUG: the original C code asserts balance == (x - y) - z (wrong formula;
// correct is x + y - z). With x=1, y=2, z=4: wrong formula gives -5 but actual
// balance is -1 — assertion fires when both deposit and withdraw complete first.
// All accesses are mutex-protected — no data race.
// TSan cannot detect this class of bug: wrong assertion formula, not a race.

procedure deposit(thread_number as int)
    lock(m)
    balance := balance + y
    deposit_done := 1
    unlock(m)
end procedure

procedure withdraw(thread_number as int)
    lock(m)
    balance := balance - z
    withdraw_done := 1
    unlock(m)
end procedure

procedure check_result(thread_number as int)
    lock(m)
    mutable dd := deposit_done
    mutable wd := withdraw_done
    mutable bal := balance
    if dd = 1 and wd = 1 then
        assert bal = (x - y) - z, "balance check"
    end if
    unlock(m)
end procedure

procedure main()
    shared mutable m as mutex := mutex()
    shared mutable x := 1
    shared mutable y := 2
    shared mutable z := 4
    shared mutable balance := 1
    shared mutable deposit_done := 0
    shared mutable withdraw_done := 0
    mutable t1 := create_threads(1, deposit)
    mutable t2 := create_threads(1, withdraw)
    mutable t3 := create_threads(1, check_result)
    join_threads(t1, 1)
    join_threads(t2, 1)
    join_threads(t3, 1)
end procedure
