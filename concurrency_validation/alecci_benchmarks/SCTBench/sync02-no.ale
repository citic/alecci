// SCTBench benchmark: concurrent-software-benchmarks/sync02_ok.c
// 1-slot producer-consumer with N=20 iterations.
// Producer waits on 'empty' when the slot is occupied; consumer waits on 'full'
// when the slot is empty. All accesses to num are under the mutex — no data race.
// Expected: no data race.

procedure producer(thread_number as int)
    mutable i := 0
    while i < 20 do
        lock(m)
        while num > 0 do
            cond_wait(empty, m)
        end while
        num := num + 1
        unlock(m)
        cond_signal(full)
        i := i + 1
    end while
end procedure

procedure consumer(thread_number as int)
    mutable j := 0
    while j < 20 do
        lock(m)
        while num = 0 do
            cond_wait(full, m)
        end while
        num := num - 1
        unlock(m)
        cond_signal(empty)
        j := j + 1
    end while
end procedure

procedure main()
    shared mutable m     as mutex   := mutex()
    shared mutable empty as condvar := condvar()
    shared mutable full  as condvar := condvar()
    shared mutable num := 0
    mutable t1 := create_threads(1, producer)
    mutable t2 := create_threads(1, consumer)
    join_threads(t1, 1)
    join_threads(t2, 1)
end procedure
