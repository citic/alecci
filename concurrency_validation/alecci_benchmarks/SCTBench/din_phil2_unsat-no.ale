// SCTBench benchmark: concurrent-software-benchmarks/din_phil2_unsat.c
// 2 dining philosophers. Each philosopher acquires right fork then left fork,
// both while holding a global esbmc_m mutex (serialising the fork operations).
// TSan sees different acquisition orders for forks[0] and forks[1] across
// threads and reports a lock-order-inversion warning.
// Expected: deadlock warning from TSan (lock-order inversion on fork mutexes).

procedure philosopher(thread_number as int)
    mutable left  := thread_number
    mutable right := (thread_number + 1) % 2
    lock(esbmc_m)
    lock(forks[right])
    lock(forks[left])
    unlock(forks[left])
    unlock(forks[right])
    unlock(esbmc_m)
end procedure

procedure main()
    shared mutable esbmc_m as mutex := mutex()
    shared mutable forks := array(2, mutex())
    mutable threads := create_threads(2, philosopher)
    join_threads(threads, 2)
end procedure
