// SCTBench benchmark: concurrent-software-benchmarks/micro_2_ok.c
// Two threads each perform 100 increments on a shared counter without any lock.
// Expected: data race on variable x.

procedure worker(thread_number as int)
    mutable i := 0
    while i < 100 do
        x := x + 1
        i := i + 1
    end while
end procedure

procedure main()
    shared mutable x := 0
    mutable threads := create_threads(2, worker)
    join_threads(threads, 2)
end procedure
