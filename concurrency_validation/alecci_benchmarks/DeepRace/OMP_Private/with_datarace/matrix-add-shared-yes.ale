// Element-wise matrix add A[6][10] + B[6][10] = C[6][10] (arrays flattened to 1D).
// 6 threads, each assigned one row via shared id/sid/eid variables.
// Race: id, sid, eid are shared — all 6 threads write them without synchronisation,
// so threads may compute wrong row ranges and corrupt each other's slots.
// Source: OMP_Private/with_datarace/ex6_-_main.c
// Ground truth: data_race (original dataset).

procedure main()
    shared mutable a := array(60, 0)
    shared mutable b := array(60, 0)
    shared mutable c := array(60, 0)
    shared mutable id as int := 0
    shared mutable sid as int := 0
    shared mutable eid as int := 0
    for i := 0 to 60 do
        a[i] := i
        b[i] := i * 2
    end for
    parallel for t := 0 to 6 with 6 thread do
        id := thread_number
        sid := id
        eid := sid + 1
        mutable j := 0
        while j < 10 do
            c[sid * 10 + j] := a[sid * 10 + j] + b[sid * 10 + j]
            j := j + 1
        end while
    end parallel for
end procedure
