// Race: parallel for accumulates isum := isum + i without mutex (missing private/reduction)
// Inspired by OMP_Private/with_datarace/data_range2_-_main.c (isum = isum + i, no reduction clause)
procedure main()
    shared mutable isum := 0
    parallel for i := 0 to 1001 with 4 thread do
        isum := isum + i
    end parallel for
end procedure
