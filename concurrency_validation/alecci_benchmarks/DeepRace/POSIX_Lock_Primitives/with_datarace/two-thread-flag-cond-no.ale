// Two-thread flag alternation using condition variable and broadcast.
// Both threads use lock before accessing flag; no data race.
// Note: uses 'if' instead of 'while' for condition check (original does too).
// Source: TwoThreadLoop.c (DeepRace POSIX/with_datarace — mislabeled, no race)

procedure thread_func()
    mutable i := 0
    while i < 50 do
        lock(lk)
        if flag != 0 then
            cond_wait(ready, lk)
        end if
        mutable j := 0
        while j < 10 do
            print("A")
            j := j + 1
        end while
        flag := flag + 1
        unlock(lk)
        cond_broadcast(ready)
        i := i + 1
    end while
end procedure

procedure main()
    shared mutable lk    as mutex   := mutex()
    shared mutable ready as condvar := condvar()
    shared mutable flag := 0
    mutable t := create_thread(thread_func)
    mutable i := 0
    while i < 50 do
        lock(lk)
        if flag != 1 then
            cond_wait(ready, lk)
        end if
        mutable j := 0
        while j < 100 do
            print("B")
            j := j + 1
        end while
        flag := flag - 1
        unlock(lk)
        cond_broadcast(ready)
        i := i + 1
    end while
    join_thread(t)
end procedure
