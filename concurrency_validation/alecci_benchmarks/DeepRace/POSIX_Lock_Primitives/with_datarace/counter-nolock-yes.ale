// Race: 4 threads increment shared counter 1000 times each without mutex
// Inspired by POSIX_Lock_Primitives/with_datarace patterns (e.g., muxtex_anpham.c base pattern)
// Race: counter (write) vs counter (read/write) across threads
procedure main()
    shared mutable counter := 0
    mutable threads := create_threads(4, worker)
    join_threads(threads, 4)
end procedure

procedure worker(thread_number as int)
    mutable i := 0
    while i < 1000 do
        counter := counter + 1
        i := i + 1
    end while
end procedure
