// Circular buffer (4 slots): producer puts 20 items then a -1 sentinel;
// consumer reads until sentinel. Two condvars prevent overflow and underflow.
// Source: ThreadSynCondition.c (DeepRace POSIX/without_datarace)

procedure put_item(data as int)
    lock(buf_lock)
    while (wpos + 1) % 4 = rpos do
        cond_wait(notfull, buf_lock)
    end while
    buf[wpos] := data
    wpos := (wpos + 1) % 4
    cond_signal(notempty)
    unlock(buf_lock)
end procedure

procedure producer()
    mutable n := 0
    while n < 20 do
        put_item(n)
        n := n + 1
    end while
    put_item(999)
end procedure

procedure consumer()
    mutable running := 1
    while running = 1 do
        lock(buf_lock)
        while wpos = rpos do
            cond_wait(notempty, buf_lock)
        end while
        mutable d := buf[rpos]
        rpos := (rpos + 1) % 4
        cond_signal(notfull)
        unlock(buf_lock)
        if d = 999 then
            running := 0
        else
            print `consumed {d}`
        end if
    end while
end procedure

procedure main()
    shared mutable buf      as array  := array(4, 0)
    shared mutable rpos := 0
    shared mutable wpos := 0
    shared mutable buf_lock  as mutex   := mutex()
    shared mutable notempty  as condvar := condvar()
    shared mutable notfull   as condvar := condvar()
    mutable t_prod := create_thread(producer)
    mutable t_cons := create_thread(consumer)
    join_thread(t_prod)
    join_thread(t_cons)
end procedure
