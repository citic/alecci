// DeepRace POSIX/without_datarace: 04-random_sleep.c
// Same ABBA lock-order inversion as lock-order-no.ale but with a random
// sleep before each acquisition. Ground truth: none (original dataset).
// TSan may report unexpected deadlock (lock-order inversion).

procedure thread1(thread_number as int)
    mutable i as int := 0
    while i < 5 do
        sleep(rand(10), "ms")
        lock(m1)
        lock(m2)
        i := i + 1
        unlock(m1)
        unlock(m2)
    end while
end procedure

procedure thread2(thread_number as int)
    mutable i as int := 0
    while i < 5 do
        sleep(rand(10), "ms")
        lock(m2)
        lock(m1)
        i := i + 1
        unlock(m2)
        unlock(m1)
    end while
end procedure

procedure main()
    shared mutable m1 as mutex := mutex()
    shared mutable m2 as mutex := mutex()
    mutable t1 := create_threads(1, thread1)
    mutable t2 := create_threads(1, thread2)
    join_threads(t1, 1)
    join_threads(t2, 1)
    print `lock order rand no end`
end procedure
