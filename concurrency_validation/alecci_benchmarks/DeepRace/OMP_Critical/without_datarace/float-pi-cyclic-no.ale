// No race: 4 threads compute cyclic PI sums locally, then merge with mutex
// Inspired by OMP_Critical/without_datarace/5_pi_smp_critical_-_main.c (local s, omp critical sum += s)
procedure main()
    shared mutable sum as float := 0.0
    shared mutable mtx as mutex := mutex()
    mutable threads := create_threads(4, worker)
    join_threads(threads, 4)
end procedure

procedure worker(thread_number as int)
    mutable step as float := 0.00001
    mutable s as float := 0.0
    mutable i := thread_number
    while i < 100000 do
        mutable x as float := i * step + step * 0.5
        s := s + 4.0 / (1.0 + (x * x))
        i := i + 4
    end while
    lock(mtx)
    sum := sum + s
    unlock(mtx)
end procedure
