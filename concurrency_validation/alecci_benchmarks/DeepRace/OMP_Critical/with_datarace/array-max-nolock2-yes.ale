// Race: parallel for finds max of arr[] without mutex (if max < arr[i] then max := arr[i])
// Inspired by OMP_Critical/with_datarace/a_-_main.c (parallel for schedule(static), no critical)
procedure main()
    shared mutable arr := array(10, 0)
    shared mutable max := 0
    mutable i := 0
    while i < 10 do
        arr[i] := (i * 7 + 3) mod 100
        i := i + 1
    end while
    max := arr[0]
    parallel for i := 0 to 10 with 4 thread do
        if max < arr[i] then
            max := arr[i]
        end if
    end parallel for
end procedure
