// Race: parallel for, shared tid := thread_number without mutex across iterations
// Inspired by OMP_Private/with_datarace/for-work-sharing_-_main.c (tid = omp_get_thread_num() shared)
procedure main()
    shared mutable tid := 0
    parallel for i := 0 to 10 with 4 thread do
        tid := thread_number
    end parallel for
end procedure
