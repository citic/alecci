// No race: parallel for uses only local (private) variables per iteration
// Inspired by OMP_Private/without_datarace/for-loop_-_main.c
// No race: c[i], a[i], b[i] each accessed by exactly one thread (distinct index i)
procedure main()
    shared mutable a := array(1000, 0)
    shared mutable b := array(1000, 0)
    shared mutable c := array(1000, 0)
    for i := 0 to 1000 do
        a[i] := i
        b[i] := i
    end for
    parallel for i := 0 to 1000 with 4 thread do
        c[i] := a[i] + b[i]
    end parallel for
end procedure
