// Race: 5 threads increment histogram buckets counts[i mod 5] without mutex
// Inspired by POSIX_Lock_Primitives/with_datarace/assiOS.c (mutex uninitialized — racy accesses)
// All threads access the same 5 buckets concurrently
// Race: counts[bucket] (write) vs counts[bucket] (read/write) across threads
procedure main()
    shared mutable counts := array(5, 0)
    mutable threads := create_threads(5, worker)
    join_threads(threads, 5)
end procedure

procedure worker(thread_number as int)
    mutable i := 0
    while i < 200 do
        mutable bucket := i mod 5
        counts[bucket] := counts[bucket] + 1
        i := i + 1
    end while
end procedure
