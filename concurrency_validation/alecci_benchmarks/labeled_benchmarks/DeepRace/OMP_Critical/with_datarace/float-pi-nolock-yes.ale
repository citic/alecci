// Race: 2 threads each compute cyclic partial float sum, then pi += sum * step without lock
// Inspired by OMP_Critical/with_datarace/exercise_3_-_main.c
procedure main()
    shared mutable pi as float := 0.0
    mutable threads := create_threads(2, worker)
    join_threads(threads, 2)
end procedure

procedure worker(thread_number as int)
    mutable step as float := 0.0001
    mutable s as float := 0.0
    mutable i := thread_number
    while i < 10000 do
        mutable x as float := i * step + step * 0.5
        s := s + 4.0 / (1.0 + (x * x))
        i := i + 2
    end while
    pi := pi + s * step
end procedure
