// DRB121 – Proper reduction: two sums accumulated with mutex protection
// sum1 = 0+1+2+3+4 = 10; sum2 = 0+1+2+3+4 = 10; var = 20
// No race: every access to sum1 and sum2 is protected by a mutex
// label: N2
procedure main()
    shared mutable sum1 := 0
    shared mutable sum2 := 0
    shared mutable mtx as mutex := mutex()
    parallel for i := 0 to 5 with 4 thread do
        lock(mtx)
        sum1 := sum1 + i
        unlock(mtx)
    end parallel for

    parallel for i := 0 to 5 with 4 thread do
        lock(mtx)
        sum2 := sum2 + i
        unlock(mtx)
    end parallel for

    mutable var := sum1 + sum2
    print `var = {var}`
end procedure
