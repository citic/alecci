// DRB029 – True dependence: a[i+1] = a[i] + 1
// Race: a[i+1] (write by iteration i) vs a[i] (read by iteration i+1 = a[i+1])
// label: Y1
procedure main()
    shared mutable a := array(100, 0)
    for i := 0 to 100 do
        a[i] := i
    end for

    parallel for i := 0 to 99 with 4 thread do
        a[i+1] := a[i] + 1
    end parallel for
end procedure
