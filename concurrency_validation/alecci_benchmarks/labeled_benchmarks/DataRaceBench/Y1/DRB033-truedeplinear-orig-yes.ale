// DRB033 – True dependence with non-unit stride: a[2*i+1] = a[i] + 1
// Race: a[2*i+1] (write) vs a[i] (read from another thread where a[i] = a[2*k+1])
// label: Y1
procedure main()
    shared mutable a := array(2000, 0)
    for i := 0 to 2000 do
        a[i] := i
    end for

    parallel for i := 0 to 1000 with 4 thread do
        a[2*i+1] := a[i] + 1
    end parallel for
end procedure
