// DRB032 – True dependence first dimension (variant): same pattern, different size
// Race: same boundary race as DRB031
// label: Y1
procedure main()
    shared mutable b := array(2500, 0)
    for i := 0 to 50 do
        for j := 0 to 50 do
            b[i * 50 + j] := 1
        end for
    end for

    parallel for i := 1 to 50 with 4 thread do
        for j := 1 to 50 do
            b[i * 50 + j] := b[(i - 1) * 50 + (j - 1)]
        end for
    end parallel for
end procedure
