// DRB018 – Missing critical: unprotected increment of shared output index
// Race: outLen (write) vs outLen (write/read) across threads
// label: Y1
procedure main()
    shared mutable input := array(1000, 0)
    shared mutable output := array(1000, 0)
    shared mutable outLen := 0
    for i := 0 to 1000 do
        input[i] := i
    end for

    parallel for i := 0 to 1000 with 4 thread do
        output[outLen] := input[i]
        outLen := outLen + 1
    end parallel for
end procedure
