// DRB075 – Thread number race: thread 0 writes numThreads, others read it concurrently
// Race: numThreads (write by thread 0) vs numThreads (read by threads 1-3) without sync
// label: Y1
procedure main()
    shared mutable numThreads := 0

    parallel for i := 0 to 4 with 4 thread do
        if thread_number = 0 then
            numThreads := 4
        else
            mutable dummy := numThreads
            dummy := dummy + 0
        end if
    end parallel for
end procedure
