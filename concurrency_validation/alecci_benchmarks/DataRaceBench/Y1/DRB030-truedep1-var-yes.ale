// DRB030 – True dependence (variant): same as DRB029 with different array size
// Race: a[i+1] (write) vs a[i] (read from adjacent iteration)
// label: Y1
procedure main()
    shared mutable a := array(200, 0)
    for i := 0 to 200 do
        a[i] := i
    end for

    parallel for i := 0 to 199 with 4 thread do
        a[i+1] := a[i] + 1
    end parallel for
end procedure
