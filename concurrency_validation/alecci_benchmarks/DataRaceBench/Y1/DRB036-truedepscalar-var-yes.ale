// DRB036 – True dependence via shared scalar (variant): larger array
// Race: tmp (write) vs tmp (read/write)
// label: Y1
procedure main()
    shared mutable a := array(500, 0)
    shared mutable tmp := 10
    parallel for i := 0 to 500 with 4 thread do
        a[i] := tmp
        tmp := a[i] + i
    end parallel for
end procedure
