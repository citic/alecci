// DRB019 – Missing critical (variant): same as DRB018 with smaller arrays
// Race: outLen (write) vs outLen (write/read)
// label: Y1
procedure main()
    shared mutable input := array(200, 0)
    shared mutable output := array(200, 0)
    shared mutable outLen := 0
    for i := 0 to 200 do
        input[i] := i
    end for

    parallel for i := 0 to 200 with 4 thread do
        output[outLen] := input[i]
        outLen := outLen + 1
    end parallel for
end procedure
