// DRB004 – Anti-dependence (2D variant): same pattern, smaller array
// Race: same boundary race as DRB003
// label: Y1
procedure main()
    shared mutable a := array(100, 0)
    for i := 0 to 10 do
        for j := 0 to 10 do
            a[i * 10 + j] := 1
        end for
    end for

    parallel for i := 0 to 9 with 4 thread do
        for j := 0 to 10 do
            a[i * 10 + j] := a[i * 10 + j] + a[(i + 1) * 10 + j]
        end for
    end parallel for
end procedure
