// DRB001 – Anti-dependence: a[i] = a[i+1] + 1
// Race: a[i+1] (read by iteration i) vs a[i+1] (written by iteration i+1 running in parallel)
// label: Y1
procedure main()
    shared mutable a := array(1000, 0)
    for i := 0 to 1000 do
        a[i] := i
    end for

    parallel for i := 0 to 999 with 4 thread do
        a[i] := a[i+1] + 1
    end parallel for
end procedure
