// DRB002 – Anti-dependence (variant): same pattern as DRB001, different array size
// Race: a[i+1] (read) vs a[i+1] (write from adjacent iteration)
// label: Y1
procedure main()
    shared mutable a := array(500, 0)
    for i := 0 to 500 do
        a[i] := i
    end for

    parallel for i := 0 to 499 with 4 thread do
        a[i] := a[i+1] + 1
    end parallel for
end procedure
