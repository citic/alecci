// DRB003 – Anti-dependence (2D): a[i*20+j] += a[(i+1)*20+j]
// Race: a[(i+1)*20+j] (read by i) vs a[(i+1)*20+j] (written by i+1, parallel)
// label: Y1
procedure main()
    shared mutable a := array(400, 0)
    for i := 0 to 20 do
        for j := 0 to 20 do
            a[i * 20 + j] := 1
        end for
    end for

    parallel for i := 0 to 19 with 4 thread do
        for j := 0 to 20 do
            a[i * 20 + j] := a[i * 20 + j] + a[(i + 1) * 20 + j]
        end for
    end parallel for
end procedure
