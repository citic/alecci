// DRB061 – Matrix-vector multiplication: outer loop (i) parallelized
// a[100][100] flattened: a[i][j] → a[i*100+j]; v[100], v_out[100] as 1D float arrays
// No race: each thread owns a unique i value and writes to v_out[i]; a and v are read-only
// Source: DataRaceBench DRB061-matrixvector1-orig-no.c
// label: N2
procedure main()
    shared mutable a := array(10000, 0.0)
    shared mutable v := array(100, 0.0)
    shared mutable v_out := array(100, 0.0)
    for i := 0 to 100 do
        v[i] := i * 1.0
        for j := 0 to 100 do
            a[i * 100 + j] := (i + j) * 0.5
        end for
    end for
    parallel for i := 0 to 100 with 4 thread do
        mutable sum as float := 0.0
        for j := 0 to 100 do
            sum := sum + a[i * 100 + j] * v[j]
        end for
        v_out[i] := sum
    end parallel for
end procedure
