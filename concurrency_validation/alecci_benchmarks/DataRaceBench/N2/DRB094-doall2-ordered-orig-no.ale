// DRB094 – DOALL2 ordered: parallel outer, sequential inner; each element independent
// No race: each thread owns its row-slice; inner j sequential per thread
// label: N2
procedure main()
    shared mutable a := array(10000, 0)

    parallel for i := 0 to 100 with 4 thread do
        for j := 0 to 100 do
            a[i * 100 + j] := a[i * 100 + j] + 1
        end for
    end parallel for
end procedure
