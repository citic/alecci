// DRB064 – Outer-only parallelism (2): b[i*100+j] = b[i*100+(j-1)], outer i parallel
// No race: each thread owns its row-range; inner j dep is sequential within each thread
// label: N2
procedure main()
    shared mutable b := array(10000, 0)
    for i := 0 to 100 do
        for j := 0 to 100 do
            b[i * 100 + j] := i * 100 + j
        end for
    end for

    parallel for i := 0 to 100 with 4 thread do
        for j := 1 to 100 do
            b[i * 100 + j] := b[i * 100 + (j - 1)]
        end for
    end parallel for
end procedure
