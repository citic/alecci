// DRB077 – Single construct: only thread 0 increments count (simulates omp single)
// No race: only one thread writes count; implicit barrier (join) before any subsequent read
// label: N1
procedure main()
    shared mutable count := 0

    parallel for i := 0 to 4 with 4 thread do
        if thread_number = 0 then
            count := count + 1
        end if
    end parallel for
end procedure
