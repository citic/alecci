// DRB011 – Missing critical: unprotected decrement of shared counter
// Race: numNodes2 (write) vs numNodes2 (write/read) across threads
// label: Y3
procedure main()
    shared mutable x := array(100, 0)
    shared mutable numNodes2 := 0
    for i := 0 to 100 do
        if i mod 2 = 0 then
            x[i] := 5
        else
            x[i] := -5
        end if
    end for

    parallel for i := 0 to 100 with 4 thread do
        if x[i] <= 0 then
            numNodes2 := numNodes2 - 1
        end if
    end parallel for
end procedure
