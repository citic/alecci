// DRB028 – Missing private: shared tmp written by all threads without synchronization
// Race: tmp (write) vs tmp (read/write) across threads
// label: Y2
procedure main()
    shared mutable a := array(100, 0)
    shared mutable tmp := 0
    for i := 0 to 100 do
        a[i] := i
    end for

    parallel for i := 0 to 100 with 4 thread do
        tmp := a[i] + i
        a[i] := tmp
    end parallel for
end procedure
