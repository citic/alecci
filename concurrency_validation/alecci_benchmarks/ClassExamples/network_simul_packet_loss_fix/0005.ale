procedure main(argc, argv)
  shared mutable packet_count := 0
  shared mutable dropped_count := 0
  mutable producers as thread_array := create_threads(3, produce)
  mutable consumers as thread_array := create_threads(3, consume)
  join_threads(producers)
  join_threads(consumers)
end procedure

procedure produce(thread_number as int)
  for i := 0 to 4 do
    sleep(rand() % 20, "ms")
    packet_count := packet_count + 1
    print("Packet sent")
  end for
end procedure

procedure consume(thread_number as int)
  for i := 0 to 4 do
    sleep(rand() % 15, "ms")
    if packet_count > 0 then
      packet_count := packet_count - 1
      print("Packet received")
    else
      dropped_count := dropped_count + 1
      print("Packet dropped")
    end if
  end for
end procedure
