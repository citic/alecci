procedure main()
  shared mutable hydrogen_multiplex := semaphore(2)
  shared mutable oxygen_multiplex := semaphore(1)  // mutex
  shared mutable device_barrier := barrier(3)
  shared mutable h_count := 0
  shared mutable o_count := 0
  shared mutable molecule_count := 0
  shared mutable bond_mutex as mutex := mutex()
  while true do
    mutable atom as char
    scan `{atom}`
    if atom = 1 then // "H"
      create_thread(hydrogen)
    else if atom = 2 then // "O"
      create_thread(oxygen)
    else
      break while
    end if
    end if
  end while
end procedure

procedure hydrogen()
  wait(hydrogen_multiplex)
  barrier_wait(device_barrier)
  bond('H')
  barrier_wait(device_barrier)
  signal(hydrogen_multiplex)
end procedure

procedure oxygen()
  wait(oxygen_multiplex)
  barrier_wait(device_barrier)
  bond('O')
  barrier_wait(device_barrier)
  signal(oxygen_multiplex)
end procedure

procedure bond(atom as char)
  lock(bond_mutex)
  if atom = 'H' then
    h_count := h_count + 1
  else if atom = 'O' then
    o_count := o_count + 1
  else
    print "Error: invalid atom type"
  end if
  end if
  if h_count = 2 and o_count = 1 then
    molecule_count := molecule_count + 1
    h_count := 0
    o_count := 0
    unlock(bond_mutex)
    print `H2O molecule {molecule_count} formed`
  else
    unlock(bond_mutex)
  end if
end procedure

