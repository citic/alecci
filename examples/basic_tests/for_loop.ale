// For loop test

procedure main()
  print `For loop test start`

  // Basic counting loop
  mutable sum := 0
  for i := 0 to 5 do
    sum := sum + i
  end for
  print `  sum 0..4 = {sum}`

  // Loop with larger range
  mutable count := 0
  for j := 1 to 11 do
    count := count + 1
  end for
  print `  count 1..10 = {count}`

  // Nested for loops
  mutable product := 0
  for row := 0 to 3 do
    for col := 0 to 3 do
      product := product + 1
    end for
  end for
  print `  3x3 iterations = {product}`

  print `For loop test end`
end procedure
