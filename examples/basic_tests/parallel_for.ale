// Parallel for tests
// Each sub-test writes to independent array indices so results are deterministic.

procedure main()
    // Test 1: 12 elements, 4 threads (evenly divisible).
    // arr[i] = i*2, sum = 2*(0+1+...+11) = 132
    shared mutable arr1 := array(12, 0)
    parallel for i := 0 to 12 with 4 thread do
        arr1[i] := i * 2
    end parallel for
    mutable sum1 := 0
    for i := 0 to 12 do
        sum1 := sum1 + arr1[i]
    end for
    print `parallel for sum (12 elems, 4 threads) = {sum1}`

    // Test 2: 10 elements, 3 threads (last thread absorbs remainder).
    // arr[i] = i+1, sum = 1+2+...+10 = 55
    shared mutable arr2 := array(10, 0)
    parallel for i := 0 to 10 with 3 thread do
        arr2[i] := i + 1
    end parallel for
    mutable sum2 := 0
    for i := 0 to 10 do
        sum2 := sum2 + arr2[i]
    end for
    print `parallel for sum (10 elems, 3 threads) = {sum2}`

    // Test 3: two sequential parallel fors over the same array.
    // First pass doubles each element (arr[i] = i*2),
    // second pass adds 1 (arr[i] = i*2 + 1).
    // Sum = sum(i*2+1 for i=0..7) = 2*(0+1+...+7) + 8 = 56 + 8 = 64
    shared mutable arr3 := array(8, 0)
    parallel for i := 0 to 8 with 4 thread do
        arr3[i] := i * 2
    end parallel for
    parallel for i := 0 to 8 with 4 thread do
        arr3[i] := arr3[i] + 1
    end parallel for
    mutable sum3 := 0
    for i := 0 to 8 do
        sum3 := sum3 + arr3[i]
    end for
    print `parallel for sum (sequential passes) = {sum3}`

    print "Parallel for test completed successfully"
end procedure
