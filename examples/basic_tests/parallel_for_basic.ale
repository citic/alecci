// Basic parallel for test: fill array in parallel, sum sequentially
procedure main(argc, argv)
    shared mutable arr := array(12, 0)

    parallel for i := 0 to 12 with 4 thread do
        arr[i] := i * 2
    end parallel for

    mutable sum := 0
    for j := 0 to 12 do
        sum := sum + arr[j]
    end for
    print `sum = {sum}`
end procedure
