// Cyclic distribution of a[i] = a[i+1]+1 across 4 threads
// Thread t handles i = t, t+4, t+8, ...
// Race: thread 0 reads a[1] while thread 1 writes a[1],
//        thread 1 reads a[2] while thread 2 writes a[2], etc.

procedure main()
    shared mutable a := array(1000, 0)
    for i := 0 to 1000 do
        a[i] := i
    end for
    mutable threads := create_threads(4, worker)
    join_threads(threads, 4)
end procedure

procedure worker(thread_number as int)
    mutable i := thread_number
    while i < 999 do
        a[i] := a[i + 1] + 1
        i := i + 4
    end while
end procedure
