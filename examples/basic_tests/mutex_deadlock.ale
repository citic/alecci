// Classic two-mutex deadlock: funcA acquires mtx_a then mtx_b;
// funcB acquires mtx_b then mtx_a.  Lock-graph cycle: mtx_a -> mtx_b -> mtx_a.
// Expected: deadlock warning from LockGraphAnalyzer.

procedure funcA(thread_number as int)
    lock(mtx_a)
    lock(mtx_b)
    unlock(mtx_b)
    unlock(mtx_a)
end procedure

procedure funcB(thread_number as int)
    lock(mtx_b)
    lock(mtx_a)
    unlock(mtx_a)
    unlock(mtx_b)
end procedure

procedure main()
    shared mutable mtx_a as mutex := mutex()
    shared mutable mtx_b as mutex := mutex()
    mutable ta := create_threads(1, funcA)
    mutable tb := create_threads(1, funcB)
    join_threads(ta, 1)
    join_threads(tb, 1)
end procedure
