// Tests that print template literals support expressions inside {}: array indexing
// with constant indices, arithmetic expressions, and variable references.
procedure main()
    shared mutable a := array(12, 0)
    shared mutable f := array(9, 0.0)
    mutable i := 2
    mutable j := 1
    for k := 0 to 12 do
        a[k] := k * 3
    end for
    for k := 0 to 9 do
        f[k] := k * 2.5
    end for
    print "print expression test"
    print `a[7]={a[7]}`
    print `a[3*2+1]={a[3 * 2 + 1]}`
    print `a[i*5+j]={a[i * 5 + j]}`
    print `f[7]={f[2 * 3 + 1]}`
    print "print expression test end"
end procedure
