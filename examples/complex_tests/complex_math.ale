// Complex test 5: Nested control flow, iterative power, Collatz sequence.
// Exercises multiple functions, while loops, for loops, if/else, and
// mixed integer arithmetic.

// 2^exp using repeated multiplication
function iter_power(base, exp)
    mutable result := 1
    mutable i := 0
    while i < exp do
        result := result * base
        i := i + 1
    end while
    return result
end function

// Sum of squares: 1^2 + 2^2 + ... + n^2
function sum_of_squares(n)
    mutable s := 0
    mutable i := 1
    while i <= n do
        s := s + i * i
        i := i + 1
    end while
    return s
end function

// Count steps to reach 1 via the Collatz (3n+1) rule
function collatz_steps(n)
    mutable steps := 0
    mutable x := n
    while x != 1 do
        if x % 2 = 0 then
            x := x / 2
        else
            x := x * 3 + 1
        end if
        steps := steps + 1
    end while
    return steps
end function

procedure main()
    print "Math test start"

    const p = iter_power(2, 8)
    print `2^8 = {p}`

    const ss = sum_of_squares(5)
    print `sum of squares 1..5 = {ss}`

    const cs = collatz_steps(27)
    print `collatz(27) steps = {cs}`

    // Count integers in [1,29] divisible by 3 or 5
    mutable count := 0
    for i := 1 to 30 do
        if i % 3 = 0 or i % 5 = 0 then
            count := count + 1
        end if
    end for
    print `multiples of 3 or 5 in 1..29 = {count}`

    print "Math test end"
end procedure
