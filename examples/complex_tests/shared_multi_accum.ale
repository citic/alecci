// Complex test 8: Two shared accumulators updated under a single mutex.
// 4 threads (k = 0..3) each lock the mutex and update both shared variables
// in one critical section, using expressions that mix local and shared values.
//
//   sum_of_ids     += k               → 0+1+2+3 = 6
//   sum_of_products += k * (4 - k)    → 0*4 + 1*3 + 2*2 + 3*1 = 0+3+4+3 = 10
//
// Tests: multiple shared variable reads in a single RHS expression,
//        multiple shared variable writes in the same locked section,
//        compound assignment expressions mixing local variables with shared state.

procedure main()
    shared mutable sum_of_ids := 0
    shared mutable sum_of_products := 0
    shared mutable m as mutex := mutex()

    print "Shared multi-accumulator test start"
    mutable threads := create_threads(4, accum_worker)
    join_threads(threads, 4)
    print `sum_of_ids = {sum_of_ids}`
    print `sum_of_products = {sum_of_products}`
    print "Shared multi-accumulator test end"
end procedure

procedure accum_worker(thread_number as int)
    mutable contrib := 4 - thread_number
    lock(m)
    sum_of_ids := sum_of_ids + thread_number
    sum_of_products := sum_of_products + thread_number * contrib
    unlock(m)
end procedure
