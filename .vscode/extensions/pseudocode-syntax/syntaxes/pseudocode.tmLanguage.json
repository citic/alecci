{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pseudocode",
  "scopeName": "source.pseudocode",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#template-strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.pseudocode",
          "match": "//.*$"
        },
        {
          "name": "comment.block.pseudocode",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.pseudocode",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.pseudocode",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.pseudocode",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.pseudocode",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "template-strings": {
      "name": "string.template.pseudocode",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "meta.embedded.line.pseudocode",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            {
              "include": "#variables"
            },
            {
              "include": "#operators"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.pseudocode",
          "match": "\\b(procedure|end|for|to|do|if|then|else|while|return|break|continue)\\b"
        },
        {
          "name": "keyword.other.pseudocode",
          "match": "\\b(shared|mutable|const|atomic|as)\\b"
        },
        {
          "name": "keyword.operator.pseudocode",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.pseudocode",
          "match": "\\b(int|float|string|bool|array|thread|mutex|semaphore)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.pseudocode",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.pseudocode",
          "match": ":="
        },
        {
          "name": "keyword.operator.comparison.pseudocode",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.pseudocode",
          "match": "(\\+|\\-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.logical.pseudocode",
          "match": "(&&|\\|\\||!)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.builtin.pseudocode",
          "match": "\\b(print|create_thread|join_thread|lock|unlock|wait|signal|array|mutex|semaphore|int|float|string)\\b"
        },
        {
          "name": "entity.name.function.pseudocode",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.pseudocode",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.pseudocode",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
