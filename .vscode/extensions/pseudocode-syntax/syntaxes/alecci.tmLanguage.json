{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Alecci",
  "scopeName": "source.alecci",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#template-strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.alecci",
          "match": "//.*$"
        },
        {
          "name": "comment.block.alecci",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.alecci",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.alecci",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.alecci",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.alecci",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "template-strings": {
      "name": "string.template.alecci",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "meta.embedded.line.alecci",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            {
              "include": "#variables"
            },
            {
              "include": "#operators"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "comment": "end <keyword> pairs — matched first so 'end' is not left plain",
          "name": "keyword.control.alecci",
          "match": "\\bend\\s+(procedure|function|if|while|parallel\\s+for|for|case|record|enum)\\b"
        },
        {
          "name": "keyword.control.alecci",
          "match": "\\b(procedure|function|return|if|then|else|while|parallel|for|do|to|with|end|break|continue|case|of)\\b"
        },
        {
          "name": "keyword.other.alecci",
          "match": "\\b(shared|mutable|const|atomic|as)\\b"
        },
        {
          "name": "keyword.operator.alecci",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.alecci",
          "match": "\\b(int|float|string|bool|array|thread|mutex|semaphore)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.alecci",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.alecci",
          "match": ":="
        },
        {
          "name": "keyword.operator.comparison.alecci",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.alecci",
          "match": "(\\+|\\-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.logical.alecci",
          "match": "(&&|\\|\\||!)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.builtin.alecci",
          "match": "\\b(print|create_thread|join_thread|lock|unlock|wait|signal|array|mutex|semaphore|int|float|string)\\b"
        },
        {
          "name": "entity.name.function.alecci",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.alecci",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.alecci",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
