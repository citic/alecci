{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Alecci",
  "scopeName": "source.alecci",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#template-strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#numbers" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.pseudocode",
          "match": "//.*$"
        },
        {
          "name": "comment.block.pseudocode",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.pseudocode",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.pseudocode",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.pseudocode",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.pseudocode",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "template-strings": {
      "name": "string.template.pseudocode",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "meta.embedded.line.pseudocode",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            { "include": "#variables" },
            { "include": "#operators" },
            { "include": "#numbers" },
            { "include": "#functions" }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "comment": "end <keyword> pairs — matched first so 'end' is not left plain",
          "name": "keyword.control.pseudocode",
          "match": "\\bend\\s+(procedure|function|if|while|for|case|record|enum)\\b"
        },
        {
          "name": "keyword.control.pseudocode",
          "match": "\\b(procedure|function|return|if|then|else|while|for|do|to|break|continue|case|of)\\b"
        },
        {
          "name": "keyword.other.pseudocode",
          "match": "\\b(shared|mutable|const|atomic|as|scan|print|mod|xor|by|pointed|variant)\\b"
        },
        {
          "name": "keyword.operator.pseudocode",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.pseudocode",
          "match": "\\b(int|float|string|bool|char|array|thread|mutex|semaphore|barrier|queue|variant)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.pseudocode",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.pseudocode",
          "match": ":="
        },
        {
          "name": "keyword.operator.comparison.pseudocode",
          "match": "(!=|<=|>=|<|>|=)"
        },
        {
          "name": "keyword.operator.arithmetic.pseudocode",
          "match": "(\\+|-|\\*|/|#|\\^|%)"
        },
        {
          "name": "keyword.operator.bitwise.pseudocode",
          "match": "(~|&|\\||<<|>>)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.builtin.pseudocode",
          "match": "\\b(print|scan|create_thread|create_threads|join_thread|join_threads|lock|unlock|wait|signal|barrier_wait|sleep|rand|array|enqueue|dequeue|queue_size|queue_capacity|mutex|semaphore|barrier|queue|thread|int|float|string)\\b"
        },
        {
          "name": "entity.name.function.pseudocode",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.pseudocode",
          "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.pseudocode",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
